<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.wps.yundoc.businesssystem.infrastructure.BizSystemApiPermissionMapper">

    <resultMap id="BizSystemApiPermissionResultMap"
               type="com.wps.yundoc.businesssystem.infrastructure.BizSystemApiPermissionPO">
        <id property="businessSystemId" column="business_system_id"/>
        <id property="apiCode" column="api_code"/>
        <result property="status" column="status"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <sql id="BizSystemApiPermissionColumns">
        business_system_id,
        api_code,
        status,
        created_at,
        updated_at
    </sql>

    <insert id="insert" parameterType="com.wps.yundoc.businesssystem.infrastructure.BizSystemApiPermissionPO">
        INSERT INTO biz_system_api_permission (
            business_system_id,
            api_code,
            status,
            created_at,
            updated_at
        ) VALUES (
            #{businessSystemId},
            #{apiCode},
            #{status},
            #{createdAt},
            #{updatedAt}
        )
    </insert>

    <insert id="insertAll">
        INSERT INTO biz_system_api_permission (
            business_system_id,
            api_code,
            status,
            created_at,
            updated_at
        ) VALUES
        <foreach collection="permissions" item="permission" separator=",">
            (
                #{permission.businessSystemId},
                #{permission.apiCode},
                #{permission.status},
                #{permission.createdAt},
                #{permission.updatedAt}
            )
        </foreach>
    </insert>

    <select id="selectByBusinessSystemIdAndApiCode" resultMap="BizSystemApiPermissionResultMap">
        SELECT
        <include refid="BizSystemApiPermissionColumns"/>
        FROM biz_system_api_permission
        WHERE business_system_id = #{businessSystemId}
          AND api_code = #{apiCode}
    </select>

    <select id="selectByBusinessSystemId" resultMap="BizSystemApiPermissionResultMap">
        SELECT
        <include refid="BizSystemApiPermissionColumns"/>
        FROM biz_system_api_permission
        WHERE business_system_id = #{businessSystemId}
        ORDER BY api_code ASC
    </select>

    <select id="selectByBusinessSystemIds" resultMap="BizSystemApiPermissionResultMap">
        SELECT
        <include refid="BizSystemApiPermissionColumns"/>
        FROM biz_system_api_permission
        WHERE business_system_id IN
        <foreach collection="businessSystemIds" item="businessSystemId" open="(" separator="," close=")">
            #{businessSystemId}
        </foreach>
        ORDER BY business_system_id ASC, api_code ASC
    </select>

    <delete id="deleteByBusinessSystemId">
        DELETE FROM biz_system_api_permission
        WHERE business_system_id = #{businessSystemId}
    </delete>
</mapper>
